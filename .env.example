# Copy this file to .env.local and fill in real values there.
# .env.local is gitignored — never commit real credentials.

# From your Supabase project's Settings -> API page.
SUPABASE_URL=https://your-project-ref.supabase.co

# The service_role key, NOT the anon/public key. Server-side only (used by
# scripts/backfill-to-supabase.ts) — never prefix this with NEXT_PUBLIC_,
# which would bundle it into client-side JS and expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Client-safe (anon) Supabase credentials — used ONLY for the magic-link
# auth handshake in the browser (src/lib/supabase/browser-client.ts). Safe to
# ship to the browser: the anon key can never read player data on its own —
# every table has RLS enabled with no public policies (see
# supabase/schema.sql). NEXT_PUBLIC_-prefixed on purpose, unlike the vars
# above. Same Project URL as SUPABASE_URL above, different key — from the
# same Settings -> API page, the "anon" / "public" key (Legacy keys tab, NOT
# the newer sb_publishable_... format — same caution as the service_role key
# below).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# From https://aistudio.google.com/apikey — free tier, no payment method
# needed at this project's usage scale. Used by scripts/parse-report.ts
# (see docs/report-parsing.md). Same rule as above: server-side/local only.
GEMINI_API_KEY=your-gemini-api-key
