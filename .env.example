# Copy this file to .env.local and fill in real values there.
# .env.local is gitignored — never commit real credentials.

# From your Supabase project's Settings -> API page.
SUPABASE_URL=https://your-project-ref.supabase.co

# The service_role key, NOT the anon/public key. Server-side only (used by
# scripts/backfill-to-supabase.ts) — never prefix this with NEXT_PUBLIC_,
# which would bundle it into client-side JS and expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
